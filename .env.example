# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe（テストモード）
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Resend（メール）
RESEND_API_KEY=re_placeholder
RESEND_FROM_EMAIL=noreply@bluesky-camp.jp
OWNER_EMAIL=owner@bluesky-camp.jp

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=placeholder
LINE_CHANNEL_SECRET=placeholder
LINE_OWNER_USER_ID=placeholder
# LINE Login channel (for LIFF idToken verify)
LINE_LOGIN_CHANNEL_ID=placeholder
# LIFF
NEXT_PUBLIC_LIFF_ID=placeholder

# === B-7b AI extraction ===
ANTHROPIC_API_KEY=sk-ant-placeholder

# === Google Drive レシート取込（経費入力） ===
# Google Cloud のサービスアカウント。Drive の仕入れレシートフォルダを
# このメールアドレスに「閲覧者」で共有すること。
GOOGLE_SERVICE_ACCOUNT_EMAIL=receipts@your-project.iam.gserviceaccount.com
# JSON キーの private_key（改行は \n のままでOK）
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# 仕入れレシートフォルダの ID（Drive でフォルダを開いた時の URL 末尾）
GOOGLE_DRIVE_RECEIPT_FOLDER_ID=placeholder
